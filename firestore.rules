rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- User Profile ---
    function isValidUserProfile(data) {
      return data.keys().hasAll(['uid', 'email', 'displayName', 'role', 'createdAt'])
        && data.keys().size() == 5
        && data.uid == request.auth.uid
        && data.email is string && data.email.size() <= 256
        && data.displayName is string && data.displayName.size() <= 128
        && data.role in ['student', 'teacher']
        && data.createdAt == request.time;
    }

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUserProfile(incoming());
      allow update: if isOwner(userId)
        && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL'])
        && incoming().displayName is string && incoming().displayName.size() <= 128;

      // --- Quiz Attempts ---
      function isValidQuizAttempt(data) {
        return data.userId == request.auth.uid
          && data.subject is string && data.subject.size() <= 50
          && data.semester is string && data.semester.size() <= 50
          && data.grade is string && data.grade.size() <= 50
          && data.score is int && data.score >= 0
          && data.totalQuestions is int && data.totalQuestions > 0
          && data.timestamp == request.time;
      }

      match /quiz_attempts/{attemptId} {
        allow list: if isOwner(userId);
        allow create: if isOwner(userId) && isValidQuizAttempt(incoming());
      }

      // --- Problem Attempts ---
      function isValidProblemAttempt(data) {
        return data.userId == request.auth.uid
          && data.subject is string && data.subject.size() <= 50
          && data.semester is string && data.semester.size() <= 50
          && data.grade is string && data.grade.size() <= 50
          && data.query is string && data.query.size() <= 2000
          && data.isSolved is bool
          && data.timestamp == request.time;
      }

      match /problem_attempts/{attemptId} {
        allow list: if isOwner(userId);
        allow create: if isOwner(userId) && isValidProblemAttempt(incoming());
      }

      // --- Areas of Difficulty ---
      function isValidArea(data) {
        return data.subject is string && data.subject.size() <= 50
          && data.topic is string && data.topic.size() <= 200
          && data.level is number && data.level >= 0 && data.level <= 1
          && data.lastUpdated == request.time;
      }

      match /areas_of_difficulty/{areaId} {
        allow list: if isOwner(userId);
        allow create, update: if isOwner(userId) && isValidArea(incoming());
        allow delete: if isOwner(userId);
      }
    }
  }
}
